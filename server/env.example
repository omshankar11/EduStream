# Server Configuration
PORT=8000
SERVER_URL=http://localhost:8000
CLIENT_URL=http://localhost:5173
NODE_ENV=development

# Database
MONGO_URI=mongodb://localhost:27017/edustream

# Authentication (Google OAuth)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
SESSION_SECRET=your_session_secret

# AI Services (Gemini) — key names must match aiRoutes.js exactly
GEMINI_API_KEY_SUMMARY=your_gemini_api_key
GEMINI_API_KEY_QUIZ=your_gemini_api_key

# AI Services (External LLM Routing)
OPENROUTER_API_KEY=your_openrouter_key_here

# External APIs
YOUTUBE_API_KEY=your_youtube_api_key

# Transcript Service
PYTHON_BIN=python
TRANSCRIPT_LANGS=en,en-US,en-GB,en-IN,hi